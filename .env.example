# ==============================
# Application
# ==============================
APP_NAME="Estimation Immobilier Nandy"
APP_BASE_URL="https://estimation-immobilier-nandy.fr"
WEBSITE_ID=1

# ==============================
# Base de données (MySQL / MariaDB)
# ==============================
DB_HOST="127.0.0.1"
DB_PORT="3306"
DB_NAME="estimation_immobilier_nandy"
DB_USER="root"
DB_PASS=""
DB_CHARSET="utf8mb4"

# ==============================
# Admin
# ==============================
ADMIN_EMAIL="contact@estimation-immobilier-nandy.fr"
ADMIN_PASSWORD=""

# ==============================
# Perplexity AI
# ==============================
PERPLEXITY_API_KEY=""
PERPLEXITY_MODEL="sonar-pro"
PERPLEXITY_ENDPOINT="https://api.perplexity.ai/chat/completions"

# ==============================
# OpenAI
# ==============================
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
OPENAI_ENDPOINT="https://api.openai.com/v1/chat/completions"

# ==============================
# Email / SMTP
# Les deux formats sont acceptes :
#   MAIL_SMTP_HOST ou MAIL_HOST
#   MAIL_SMTP_PORT ou MAIL_PORT
#   MAIL_SMTP_USER ou MAIL_USERNAME
#   MAIL_SMTP_PASS ou MAIL_PASSWORD
#   MAIL_SMTP_ENCRYPTION ou MAIL_ENCRYPTION
#   MAIL_FROM ou MAIL_FROM_ADDRESS
#
# IMPORTANT (o2switch / hebergement mutualise) :
#   - MAIL_FROM doit correspondre au MAIL_USERNAME pour l'alignement SPF
#   - Configurez SPF et DKIM dans votre zone DNS (cPanel > Email Deliverability)
#   - Doc : https://faq.o2switch.fr/hebergement-mutualise/tutoriels-cpanel/authentification-email-spf-dkim
# ==============================
MAIL_FROM="contact@estimation-immobilier-nandy.fr"
MAIL_FROM_NAME="Estimation Immobilier Nandy"
MAIL_HOST="mail.estimation-immobilier-nandy.fr"
MAIL_PORT="465"
MAIL_USERNAME="contact@estimation-immobilier-nandy.fr"
MAIL_PASSWORD=""
MAIL_ENCRYPTION="ssl"

# ==============================
# Couleurs du site
# ==============================
SITE_COLOR_BG="#faf9f7"
SITE_COLOR_SURFACE="#ffffff"
SITE_COLOR_TEXT="#1a1410"
SITE_COLOR_MUTED="#6b6459"
SITE_COLOR_PRIMARY="#2E7D32"
SITE_COLOR_PRIMARY_DARK="#1B5E20"
SITE_COLOR_ACCENT="#FF8F00"
SITE_COLOR_ACCENT_LIGHT="#FFB300"
SITE_COLOR_BORDER="#e8dfd7"
SITE_COLOR_SUCCESS="#22c55e"
SITE_COLOR_WARNING="#f97316"
SITE_COLOR_DANGER="#e24b4a"
SITE_COLOR_INFO="#3b82f6"
SITE_COLOR_NEUTRAL="#000000"

# ==============================
# Claude (Anthropic)
# ==============================
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-20250514"

# ==============================
# Google Maps Places
# ==============================
GOOGLE_MAPS_API_KEY=""

# ==============================
# SMS Partner
# ==============================
SMSPARTNER_API_KEY=""

# ==============================
# Twilio
# ==============================
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# ==============================
# Développement
# ==============================
# Passer à true pour accéder au dashboard sans login
DEV_SKIP_AUTH=false

# ==============================
# Maintenance
# ==============================
MAINTENANCE_MODE=false
MAINTENANCE_RETRY_AFTER=3600
